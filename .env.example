# Optional - default upstream fallback
# 多上游请优先在管理后台「系统 / 上游配置」里配置。
# 下面这组只作为首次启动或未配置后台上游时的默认兜底。
IMAGE_API_KEY=
IMAGE_API_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-2
IMAGE_API_TIMEOUT=360
IMAGE_RESPONSE_FORMAT=

# Required - Secrets (must change before first run)
OWNER_SECRET=replace-with-a-long-random-string
COOKIE_SIGNING_SECRET=replace-with-another-random-string
ADMIN_PASSWORD=replace-with-admin-password

# Optional
IMAGE_API_TOKEN=your-api-token
MIN_WEB_PASSPHRASE_LENGTH=6
ADMIN_PAGE_PATH=/admin
COOKIE_SECURE=0
HOST=0.0.0.0
PORT=30116
